# MCPHub Configuration
# Copy this file to .env and fill in your values

# Orchestrator
MCPHUB_HOST=127.0.0.1
MCPHUB_PORT=8000
MCPHUB_API_KEY=your-secret-api-key-here
MCPHUB_SECRET_KEY=your-secret-key-here
MCPHUB_CORS_ORIGIN=http://localhost:8000

# Notifications — Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Notifications — Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Notifications — WhatsApp (Meta Business API)
WHATSAPP_API_KEY=your-whatsapp-business-api-key

# AI (for future AI-powered summaries)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Database
DATABASE_URL=sqlite:///mcphub.db

# Scanner
SCAN_TIMEOUT=30
